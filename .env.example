# KKBox application database
POSTGRES_USER=bt4301
POSTGRES_PASSWORD=bt4301pass
POSTGRES_DB=kkbox

# MLflow tracking server database
# macOS: set MLFLOW_POSTGRES_USER to your system username (run `whoami`), leave password blank
# Windows: set MLFLOW_POSTGRES_USER=postgres and supply a password
MLFLOW_POSTGRES_USER=postgres
MLFLOW_POSTGRES_PASSWORD=
MLFLOW_POSTGRES_DB=mlflow_db
MLFLOW_PORT=5001

# Airflow admin credentials
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
